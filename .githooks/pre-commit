#!/bin/bash
# Block known secret formats in staged diffs. No broad "looks like base64/hex"
# heuristics — those false-positive on normal code and test names.

RED="\033[0;31m"
NC="\033[0m"

FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
	exit 0
fi

FOUND=0

check_pattern() {
	local pattern="$1"
	local description="$2"
	local matches
	matches=$(git diff --cached -U0 -- $FILES | /usr/bin/grep -v '^+++' | /usr/bin/grep -nE "^\+.*${pattern}" || true)
	if [ -n "$matches" ]; then
		echo -e "${RED}[BLOCKED] ${description}${NC}"
		echo "$matches"
		echo ""
		FOUND=1
	fi
}

check_pattern "sk-[a-zA-Z0-9]{20,}" "OpenAI/OpenCode-style API key (sk-...)"
check_pattern "AKIA[0-9A-Z]{16}" "AWS Access Key ID"
check_pattern "ghp_[a-zA-Z0-9]{36}" "GitHub Personal Access Token (classic)"
check_pattern "github_pat_[a-zA-Z0-9_]{22,}" "GitHub Personal Access Token (fine-grained)"
check_pattern "ya29\.[a-zA-Z0-9_-]{50,}" "Google OAuth Token"
check_pattern "eyJ[a-zA-Z0-9_-]{50,}\.[a-zA-Z0-9_-]{20,}\.[a-zA-Z0-9_-]{20,}" "JWT Token"
check_pattern "-----BEGIN (RSA |EC )?PRIVATE KEY-----" "Private Key Block"

if [ $FOUND -eq 1 ]; then
	echo ""
	echo -e "${RED}Commit blocked: sensitive data detected.${NC}"
	echo "If this is a false positive, use: git commit --no-verify"
	exit 1
fi

exit 0